#!/usr/bin/env bash
set -euo pipefail

ROOT="/app/s"
SRC_ROOT="$ROOT/src"
CALLER_DIR="$(pwd)"

args=("$@")

if [ "${#args[@]}" -ge 2 ]; then
    case "${args[0]}" in
        check|build|run)
            if [[ "${args[1]}" != /* ]]; then
                args[1]="$CALLER_DIR/${args[1]}"
            fi
            ;;
    esac
fi

cd "$SRC_ROOT"
exec python3 -m compiler "${args[@]}"
