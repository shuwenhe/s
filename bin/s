#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${S_ROOT:-}" ]]; then
  ROOT_DIR="$S_ROOT"
elif [[ -d "/app/s/bin" ]]; then
  ROOT_DIR="/app/s"
else
  ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fi

declare -a TMP_FILES=()

cleanup_tmp_files() {
  local f
  for f in "${TMP_FILES[@]:-}"; do
    if [[ -n "$f" && -e "$f" ]]; then
      rm -f "$f"
    fi
  done
  return 0
}

register_tmp_file() {
  TMP_FILES+=("$1")
}

trap cleanup_tmp_files EXIT

pick_compiler() {
  local arch
  arch="$(uname -m)"

  case "$arch" in
    aarch64|arm64)
      ls -1t "$ROOT_DIR"/bin/s_arm64_* 2>/dev/null | head -n 1
      ;;
    x86_64|amd64)
      if [[ -x "$ROOT_DIR/bin/s_x86_64" ]]; then
        echo "$ROOT_DIR/bin/s_x86_64"
      else
        ls -1t "$ROOT_DIR"/bin/s_x86_64_* 2>/dev/null | head -n 1
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

usage() {
  cat <<'EOF'
usage:
  s check <input.s>
  s ir <input.s> -o <output.ir>
  s build <input.s> -o <output.bin>
  s run <input.s>
  s test [fixtures_root]
  s test --all [fixtures_root]
  s fmt [path ...]
  s lint [path ...]
  s mod init <module>
  s mod tidy
  s mod show
  s doc [path]
  s pkg list [path]
  s emit-bin <input.ir> -o <output.bin>
  s bootstrap <compiler_source.s> [output_dir]

notes:
  - current native backend supports source -> ir and ir -> native compiler artifact.
  - s build generates an executable launcher script plus a sibling .ir file.
  - s run executes IR through the seed runtime interpreter path.
  - s test defaults to a stable smoke fixture set.
  - use s test --all to run all fixtures for capability tracking.
  - s fmt/s lint/s mod are not implemented in this wrapper yet.
EOF
}

default_test_root() {
  echo "$ROOT_DIR/src/cmd/compile/internal/tests/fixtures"
}

collect_s_files() {
  local paths=()
  local p
  if [[ $# -eq 0 ]]; then
    paths=(".")
  else
    paths=("$@")
  fi

  for p in "${paths[@]}"; do
    if [[ -f "$p" ]]; then
      [[ "$p" == *.s ]] && echo "$p"
    elif [[ -d "$p" ]]; then
      find "$p" -type f -name '*.s'
    fi
  done | sort -u
}

extract_package_name() {
  local file="$1"
  awk '/^[[:space:]]*package[[:space:]]+[A-Za-z0-9_.]+[[:space:]]*$/ { print $2; exit }' "$file"
}

smoke_fixture_list() {
  local root="$1"
  cat <<EOF
$root/binary_sample.s
$root/borrow_fail.s
$root/branch_move_fail.s
$root/builtin_field_ok.s
$root/check_fail.s
$root/generic_bound_fail.s
$root/method_conflict_fail.s
EOF
}

ensure_ir_runner() {
  local arch runner src
  arch="$(uname -m)"
  runner="/tmp/s_ir_runner_${arch}"
  src="/tmp/s_ir_runner_main_${arch}.c"

  if [[ -x "$runner" ]]; then
    echo "$runner"
    return 0
  fi

  cat >"$src" <<'EOF'
#include <stdio.h>
#include <stdlib.h>

#include "runtime/memory.h"

int main(int argc, char **argv) {
  compile_error err;
  long ret = 0;
  const char *entry = "main";

  if (argc < 2 || argc > 3) {
    fprintf(stderr, "usage: %s <input.ir> [entry]\n", argv[0]);
    return 2;
  }
  if (argc == 3) {
    entry = argv[2];
  }

  if (!runtime_execute_file(argv[1], entry, &ret, &err)) {
    fprintf(stderr, "error[%d] at %zu:%zu: %s\n", (int)err.code, err.line, err.column, err.message);
    return 1;
  }

  return (int)ret;
}
EOF

  gcc -std=c11 -Wall -Wextra -Werror -O2 \
    -I"$ROOT_DIR/src/cmd/compile/seed" \
    -o "$runner" \
    "$src" \
    "$ROOT_DIR/src/cmd/compile/seed/lexical/lexer.c" \
    "$ROOT_DIR/src/cmd/compile/seed/syntax/parser.c" \
    "$ROOT_DIR/src/cmd/compile/seed/semantic/analyzer.c" \
    "$ROOT_DIR/src/cmd/compile/seed/intermediate/ir.c" \
    "$ROOT_DIR/src/cmd/compile/seed/code/generator.c" \
    "$ROOT_DIR/src/cmd/compile/seed/code/native_backend.c" \
    "$ROOT_DIR/src/cmd/compile/seed/runtime/runtime.c" \
    "$ROOT_DIR/src/cmd/compile/seed/error/error.c"

  echo "$runner"
}

fail_unimplemented() {
  echo "error: '$1' is not implemented in this wrapper yet" >&2
  echo "hint: use 's check', 's ir', 's build', 's run', 's test', 's fmt', 's lint', 's mod', 's doc', 's pkg', 's emit-bin', or 's bootstrap'" >&2
  exit 2
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

COMPILER="$(pick_compiler || true)"
if [[ -z "$COMPILER" || ! -x "$COMPILER" ]]; then
  echo "error: no runnable native s compiler found for arch '$(uname -m)'" >&2
  exit 1
fi

cmd="$1"
shift

case "$cmd" in
  check)
    if [[ $# -ne 1 ]]; then
      echo "error: usage: s check <input.s>" >&2
      exit 2
    fi
    tmp_ir="$(mktemp /tmp/s_check.XXXXXX.ir)"
    trap 'rm -f "$tmp_ir"' EXIT
    "$COMPILER" "$1" "$tmp_ir" >/dev/null
    echo "ok: $1"
    ;;
  ir)
    if [[ $# -ne 3 || "$2" != "-o" ]]; then
      echo "error: usage: s ir <input.s> -o <output.ir>" >&2
      exit 2
    fi
    "$COMPILER" "$1" "$3"
    ;;
  emit-bin)
    if [[ $# -ne 3 || "$2" != "-o" ]]; then
      echo "error: usage: s emit-bin <input.ir> -o <output.bin>" >&2
      exit 2
    fi
    "$COMPILER" --emit-bin "$1" "$3"
    ;;
  build)
    if [[ $# -ne 3 || "$2" != "-o" ]]; then
      echo "error: usage: s build <input.s> -o <output.bin>" >&2
      exit 2
    fi
    in_src="$1"
    out_bin="$3"
    out_ir="${out_bin}.ir"
    out_dir="$(dirname "$out_bin")"
    out_ir_base="$(basename "$out_ir")"

    mkdir -p "$out_dir"
    "$COMPILER" "$in_src" "$out_ir" >/dev/null
    runner="$(ensure_ir_runner)"

    cat >"$out_bin" <<EOF
#!/usr/bin/env bash
set -euo pipefail
HERE="\$(cd "\$(dirname "\$0")" && pwd)"
exec "$runner" "\$HERE/$out_ir_base"
EOF
    chmod +x "$out_bin"
    echo "built $in_src -> $out_bin"
    ;;
  bootstrap)
    if [[ $# -lt 1 || $# -gt 2 ]]; then
      echo "error: usage: s bootstrap <compiler_source.s> [output_dir]" >&2
      exit 2
    fi
    if [[ $# -eq 1 ]]; then
      "$COMPILER" --bootstrap "$1"
    else
      "$COMPILER" --bootstrap "$1" "$2"
    fi
    ;;
  run)
    if [[ $# -ne 1 ]]; then
      echo "error: usage: s run <input.s>" >&2
      exit 2
    fi
    run_src="$1"
    tmp_ir="$(mktemp /tmp/s_run.XXXXXX.ir)"
    register_tmp_file "$tmp_ir"

    "$COMPILER" "$run_src" "$tmp_ir" >/dev/null
    runner="$(ensure_ir_runner)"
    "$runner" "$tmp_ir"
    ;;
  test)
    mode="smoke"
    fixtures_root="$(default_test_root)"

    if [[ $# -gt 0 && "$1" == "--all" ]]; then
      mode="all"
      shift
    fi

    if [[ $# -gt 1 ]]; then
      echo "error: usage: s test [fixtures_root] | s test --all [fixtures_root]" >&2
      exit 2
    fi

    if [[ $# -eq 1 ]]; then
      fixtures_root="$1"
    fi

    if [[ ! -d "$fixtures_root" ]]; then
      echo "error: fixtures root not found: $fixtures_root" >&2
      exit 1
    fi

    total=0
    passed=0
    failed=0

    file_list="$(mktemp /tmp/s_test_files.XXXXXX)"
    register_tmp_file "$file_list"

    if [[ "$mode" == "all" ]]; then
      echo "running full fixture suite: $fixtures_root"
      find "$fixtures_root" -type f -name '*.s' | sort >"$file_list"
    else
      echo "running smoke fixture suite: $fixtures_root"
      smoke_fixture_list "$fixtures_root" >"$file_list"
    fi

    while IFS= read -r file; do
      if [[ -z "$file" ]]; then
        continue
      fi
      if [[ ! -f "$file" ]]; then
        echo "FAIL (missing fixture): $file"
        failed=$((failed + 1))
        total=$((total + 1))
        continue
      fi

      total=$((total + 1))
      tmp_ir="$(mktemp /tmp/s_test.XXXXXX.ir)"
      register_tmp_file "$tmp_ir"

      if [[ "$file" == *_fail.s ]]; then
        if "$COMPILER" "$file" "$tmp_ir" >/dev/null 2>&1; then
          echo "FAIL (expected error): $file"
          failed=$((failed + 1))
        else
          echo "ok (expected fail): $file"
          passed=$((passed + 1))
        fi
      else
        if "$COMPILER" "$file" "$tmp_ir" >/dev/null 2>&1; then
          echo "ok: $file"
          passed=$((passed + 1))
        else
          echo "FAIL (unexpected error): $file"
          failed=$((failed + 1))
        fi
      fi
    done <"$file_list"

    echo "test summary: total=$total passed=$passed failed=$failed"
    if [[ $failed -ne 0 ]]; then
      exit 1
    fi
    ;;
  fmt)
    changed=0
    checked=0
    while IFS= read -r file; do
      [[ -z "$file" ]] && continue
      checked=$((checked + 1))
      tmp_fmt="$(mktemp /tmp/s_fmt.XXXXXX.s)"
      register_tmp_file "$tmp_fmt"

      awk '{ sub(/[[:space:]]+$/, ""); sub(/\r$/, ""); print }' "$file" >"$tmp_fmt"
      if ! cmp -s "$file" "$tmp_fmt"; then
        cp "$tmp_fmt" "$file"
        echo "fmt: $file"
        changed=$((changed + 1))
      fi
    done < <(collect_s_files "$@")

    echo "fmt summary: files=$checked changed=$changed"
    ;;
  lint)
    lint_total=0
    lint_failed=0

    while IFS= read -r file; do
      [[ -z "$file" ]] && continue
      lint_total=$((lint_total + 1))

      if [[ "$file" == *_fail.s ]]; then
        echo "lint skip (expected-fail fixture): $file"
        continue
      fi

      if grep -n $'\t' "$file" >/dev/null 2>&1; then
        echo "lint FAIL (tab indentation): $file"
        lint_failed=$((lint_failed + 1))
        continue
      fi

      if grep -nE '[[:space:]]+$' "$file" >/dev/null 2>&1; then
        echo "lint FAIL (trailing whitespace): $file"
        lint_failed=$((lint_failed + 1))
        continue
      fi

      pkg_name="$(extract_package_name "$file" || true)"
      if [[ -z "$pkg_name" ]]; then
        echo "lint FAIL (missing package declaration): $file"
        lint_failed=$((lint_failed + 1))
        continue
      fi

      tmp_ir="$(mktemp /tmp/s_lint.XXXXXX.ir)"
      register_tmp_file "$tmp_ir"
      if "$COMPILER" "$file" "$tmp_ir" >/dev/null 2>&1; then
        echo "lint ok: $file"
      else
        echo "lint FAIL (compile check): $file"
        lint_failed=$((lint_failed + 1))
      fi
    done < <(collect_s_files "$@")

    echo "lint summary: files=$lint_total failed=$lint_failed"
    if [[ $lint_failed -ne 0 ]]; then
      exit 1
    fi
    ;;
  mod)
    if [[ $# -lt 1 ]]; then
      echo "error: usage: s mod <init|tidy|show> [args]" >&2
      exit 2
    fi

    mod_cmd="$1"
    shift
    mod_file="$(pwd)/s.mod"

    case "$mod_cmd" in
      init)
        if [[ $# -ne 1 ]]; then
          echo "error: usage: s mod init <module>" >&2
          exit 2
        fi
        if [[ -f "$mod_file" ]]; then
          echo "error: s.mod already exists: $mod_file" >&2
          exit 1
        fi
        cat >"$mod_file" <<EOF
[module]
name = "$1"
version = "0.1.0"
edition = "2026"

[dependencies]
EOF
        echo "mod init: created $mod_file"
        ;;
      tidy)
        if [[ $# -ne 0 ]]; then
          echo "error: usage: s mod tidy" >&2
          exit 2
        fi
        if [[ ! -f "$mod_file" ]]; then
          echo "error: s.mod not found in $(pwd)" >&2
          exit 1
        fi
        if ! rg -n '^\[module\]' "$mod_file" >/dev/null 2>&1; then
          echo "error: invalid s.mod: missing [module]" >&2
          exit 1
        fi
        if ! rg -n '^\[dependencies\]' "$mod_file" >/dev/null 2>&1; then
          echo "[dependencies]" >>"$mod_file"
        fi
        echo "mod tidy: ok"
        ;;
      show)
        if [[ $# -ne 0 ]]; then
          echo "error: usage: s mod show" >&2
          exit 2
        fi
        if [[ ! -f "$mod_file" ]]; then
          echo "error: s.mod not found in $(pwd)" >&2
          exit 1
        fi
        cat "$mod_file"
        ;;
      *)
        echo "error: unknown mod subcommand '$mod_cmd'" >&2
        echo "usage: s mod <init|tidy|show>" >&2
        exit 2
        ;;
    esac
    ;;
  doc)
    if [[ $# -gt 1 ]]; then
      echo "error: usage: s doc [path]" >&2
      exit 2
    fi

    doc_path="${1:-.}"
    files=()
    while IFS= read -r f; do
      [[ -n "$f" ]] && files+=("$f")
    done < <(collect_s_files "$doc_path")

    if [[ ${#files[@]} -eq 0 ]]; then
      echo "error: no .s files found under $doc_path" >&2
      exit 1
    fi

    for file in "${files[@]}"; do
      pkg_name="$(extract_package_name "$file" || true)"
      [[ -z "$pkg_name" ]] && pkg_name="unknown"
      echo "=== $file (package $pkg_name) ==="
      awk '
        /^\s*\/\// { comment = comment $0 "\n"; next }
        /^\s*(func|struct|enum|trait|impl)\s+/ {
          gsub(/^\s+/, "", $0)
          if (comment != "") {
            printf "%s", comment
            comment = ""
          }
          print $0
          print ""
          next
        }
        { comment = "" }
      ' "$file"
    done
    ;;
  pkg)
    if [[ $# -lt 1 || $# -gt 2 ]]; then
      echo "error: usage: s pkg list [path]" >&2
      exit 2
    fi

    pkg_cmd="$1"
    shift
    pkg_path="${1:-.}"

    case "$pkg_cmd" in
      list)
        tmp_pkg="$(mktemp /tmp/s_pkg.XXXXXX)"
        register_tmp_file "$tmp_pkg"
        while IFS= read -r file; do
          [[ -z "$file" ]] && continue
          pkg_name="$(extract_package_name "$file" || true)"
          [[ -z "$pkg_name" ]] && pkg_name="unknown"
          printf "%s\t%s\n" "$pkg_name" "$file" >>"$tmp_pkg"
        done < <(collect_s_files "$pkg_path")

        if [[ ! -s "$tmp_pkg" ]]; then
          echo "error: no .s files found under $pkg_path" >&2
          exit 1
        fi

        awk -F '\t' '{count[$1]++} END {for (k in count) printf "%s\t%d\n", k, count[k]}' "$tmp_pkg" | sort
        ;;
      *)
        echo "error: unknown pkg subcommand '$pkg_cmd'" >&2
        echo "usage: s pkg list [path]" >&2
        exit 2
        ;;
    esac
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "error: unknown command '$cmd'" >&2
    usage
    exit 2
    ;;
esac
