#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${S_ROOT:-}" ]]; then
  ROOT_DIR="$S_ROOT"
elif [[ -d "/app/s/bin" ]]; then
  ROOT_DIR="/app/s"
else
  ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fi

pick_compiler() {
  local arch
  arch="$(uname -m)"

  case "$arch" in
    aarch64|arm64)
      ls -1t "$ROOT_DIR"/bin/s_arm64_* 2>/dev/null | head -n 1
      ;;
    x86_64|amd64)
      if [[ -x "$ROOT_DIR/bin/s_x86_64" ]]; then
        echo "$ROOT_DIR/bin/s_x86_64"
      else
        ls -1t "$ROOT_DIR"/bin/s_x86_64_* 2>/dev/null | head -n 1
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

usage() {
  cat <<'EOF'
usage:
  s check <input.s>
  s ir <input.s> -o <output.ir>
  s build <input.s> -o <output.bin>
  s run <input.s>
  s test [fixtures_root]
  s emit-bin <input.ir> -o <output.bin>
  s bootstrap <compiler_source.s> [output_dir]

notes:
  - current native backend supports source -> ir and ir -> native compiler artifact.
  - s build generates an executable launcher script plus a sibling .ir file.
  - s run executes IR through the seed runtime interpreter path.
  - s fmt/s lint/s mod are not implemented in this wrapper yet.
EOF
}

ensure_ir_runner() {
  local arch runner src
  arch="$(uname -m)"
  runner="/tmp/s_ir_runner_${arch}"
  src="/tmp/s_ir_runner_main_${arch}.c"

  if [[ -x "$runner" ]]; then
    echo "$runner"
    return 0
  fi

  cat >"$src" <<'EOF'
#include <stdio.h>
#include <stdlib.h>

#include "runtime/memory.h"

int main(int argc, char **argv) {
  compile_error err;
  long ret = 0;
  const char *entry = "main";

  if (argc < 2 || argc > 3) {
    fprintf(stderr, "usage: %s <input.ir> [entry]\n", argv[0]);
    return 2;
  }
  if (argc == 3) {
    entry = argv[2];
  }

  if (!runtime_execute_file(argv[1], entry, &ret, &err)) {
    fprintf(stderr, "error[%d] at %zu:%zu: %s\n", (int)err.code, err.line, err.column, err.message);
    return 1;
  }

  return (int)ret;
}
EOF

  gcc -std=c11 -Wall -Wextra -Werror -O2 \
    -I"$ROOT_DIR/src/cmd/compile/seed" \
    -o "$runner" \
    "$src" \
    "$ROOT_DIR/src/cmd/compile/seed/lexical/lexer.c" \
    "$ROOT_DIR/src/cmd/compile/seed/syntax/parser.c" \
    "$ROOT_DIR/src/cmd/compile/seed/semantic/analyzer.c" \
    "$ROOT_DIR/src/cmd/compile/seed/intermediate/ir.c" \
    "$ROOT_DIR/src/cmd/compile/seed/code/generator.c" \
    "$ROOT_DIR/src/cmd/compile/seed/code/native_backend.c" \
    "$ROOT_DIR/src/cmd/compile/seed/runtime/runtime.c" \
    "$ROOT_DIR/src/cmd/compile/seed/error/error.c"

  echo "$runner"
}

fail_unimplemented() {
  echo "error: '$1' is not implemented in this wrapper yet" >&2
  echo "hint: use 's check', 's ir', 's build', 's run', 's test', 's emit-bin', or 's bootstrap'" >&2
  exit 2
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

COMPILER="$(pick_compiler || true)"
if [[ -z "$COMPILER" || ! -x "$COMPILER" ]]; then
  echo "error: no runnable native s compiler found for arch '$(uname -m)'" >&2
  exit 1
fi

cmd="$1"
shift

case "$cmd" in
  check)
    if [[ $# -ne 1 ]]; then
      echo "error: usage: s check <input.s>" >&2
      exit 2
    fi
    tmp_ir="$(mktemp /tmp/s_check.XXXXXX.ir)"
    trap 'rm -f "$tmp_ir"' EXIT
    "$COMPILER" "$1" "$tmp_ir" >/dev/null
    echo "ok: $1"
    ;;
  ir)
    if [[ $# -ne 3 || "$2" != "-o" ]]; then
      echo "error: usage: s ir <input.s> -o <output.ir>" >&2
      exit 2
    fi
    "$COMPILER" "$1" "$3"
    ;;
  emit-bin)
    if [[ $# -ne 3 || "$2" != "-o" ]]; then
      echo "error: usage: s emit-bin <input.ir> -o <output.bin>" >&2
      exit 2
    fi
    "$COMPILER" --emit-bin "$1" "$3"
    ;;
  build)
    if [[ $# -ne 3 || "$2" != "-o" ]]; then
      echo "error: usage: s build <input.s> -o <output.bin>" >&2
      exit 2
    fi
    in_src="$1"
    out_bin="$3"
    out_ir="${out_bin}.ir"
    out_dir="$(dirname "$out_bin")"
    out_ir_base="$(basename "$out_ir")"

    mkdir -p "$out_dir"
    "$COMPILER" "$in_src" "$out_ir" >/dev/null
    runner="$(ensure_ir_runner)"

    cat >"$out_bin" <<EOF
#!/usr/bin/env bash
set -euo pipefail
HERE="\$(cd "\$(dirname "\$0")" && pwd)"
exec "$runner" "\$HERE/$out_ir_base"
EOF
    chmod +x "$out_bin"
    echo "built $in_src -> $out_bin"
    ;;
  bootstrap)
    if [[ $# -lt 1 || $# -gt 2 ]]; then
      echo "error: usage: s bootstrap <compiler_source.s> [output_dir]" >&2
      exit 2
    fi
    if [[ $# -eq 1 ]]; then
      "$COMPILER" --bootstrap "$1"
    else
      "$COMPILER" --bootstrap "$1" "$2"
    fi
    ;;
  run)
    if [[ $# -ne 1 ]]; then
      echo "error: usage: s run <input.s>" >&2
      exit 2
    fi
    run_src="$1"
    compat_src=""
    tmp_ir="$(mktemp /tmp/s_run.XXXXXX.ir)"

    if grep -Eq '\bprintln\(' "$run_src"; then
      compat_src="$(mktemp /tmp/s_run_src.XXXXXX.s)"
      sed -E 's/\bprintln\(/print(/g' "$run_src" > "$compat_src"
      run_src="$compat_src"
      echo "warning: println is not runtime-native yet; mapped to print for 's run'" >&2
    fi

    trap 'rm -f "$tmp_ir" "$compat_src"' EXIT
    "$COMPILER" "$run_src" "$tmp_ir" >/dev/null
    runner="$(ensure_ir_runner)"
    "$runner" "$tmp_ir"
    ;;
  test)
    if [[ $# -gt 1 ]]; then
      echo "error: usage: s test [fixtures_root]" >&2
      exit 2
    fi

    fixtures_root="${1:-$ROOT_DIR/src/cmd/compile/internal/tests/fixtures}"
    if [[ ! -d "$fixtures_root" ]]; then
      echo "error: fixtures root not found: $fixtures_root" >&2
      exit 1
    fi

    total=0
    passed=0
    failed=0

    while IFS= read -r file; do
      total=$((total + 1))
      tmp_ir="$(mktemp /tmp/s_test.XXXXXX.ir)"

      if [[ "$file" == *_fail.s ]]; then
        if "$COMPILER" "$file" "$tmp_ir" >/dev/null 2>&1; then
          echo "FAIL (expected error): $file"
          failed=$((failed + 1))
        else
          echo "ok (expected fail): $file"
          passed=$((passed + 1))
        fi
      else
        if "$COMPILER" "$file" "$tmp_ir" >/dev/null 2>&1; then
          echo "ok: $file"
          passed=$((passed + 1))
        else
          echo "FAIL (unexpected error): $file"
          failed=$((failed + 1))
        fi
      fi

      rm -f "$tmp_ir"
    done < <(find "$fixtures_root" -type f -name '*.s' | sort)

    echo "test summary: total=$total passed=$passed failed=$failed"
    if [[ $failed -ne 0 ]]; then
      exit 1
    fi
    ;;
  fmt|lint|doc|pkg|mod)
    fail_unimplemented "$cmd"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "error: unknown command '$cmd'" >&2
    usage
    exit 2
    ;;
esac
