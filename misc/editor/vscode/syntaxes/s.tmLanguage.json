{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "S",
  "scopeName": "source.s",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#modules"
    },
    {
      "include": "#storage"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#types"
    },
    {
      "include": "#generics"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#traits"
    },
    {
      "include": "#variants"
    },
    {
      "include": "#matchPatterns"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.s",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.s"
            }
          },
          "end": "$"
        },
        {
          "name": "comment.block.s",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.s"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.s"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.s",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.s"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.s"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.s",
              "switch": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.s",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.s"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.s"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.s",
              "switch": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.s",
          "switch": "\\b(?:0x[0-9A-Fa-f_]+|0b[01_]+|0o[0-7_]+|\\d+(?:_\\d+)*(?:\\.\\d+(?:_\\d+)*)?)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.s",
          "switch": "\\b(?:if|else|for|while|switch|return|break|continue)\\b"
        },
        {
          "name": "keyword.other.s",
          "switch": "\\b(?:package|use|as|in|where|unsafe|extern|mut|pub|let)\\b"
        },
        {
          "name": "constant.language.boolean.s",
          "switch": "\\b(?:true|false)\\b"
        }
      ]
    },
    "modules": {
      "patterns": [
        {
          "name": "entity.name.namespace.package.s",
          "switch": "(?<=\\bpackage\\s)([a-zA-Z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)"
        },
        {
          "name": "entity.name.namespace.import.s",
          "switch": "(?<=\\buse\\s)([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)"
        },
        {
          "name": "entity.name.namespace.import.alias.s",
          "switch": "(?<=\\bas\\s)([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.modifier.s",
          "switch": "\\b(?:const|static|mut)\\b"
        },
        {
          "name": "storage.type.declaration.s",
          "switch": "\\b(?:func|fn|let|var|struct|enum|trait|impl|for)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "entity.name.type.trait.s",
          "switch": "(?<=\\btrait\\s)([A-Z][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.type.struct.s",
          "switch": "(?<=\\bstruct\\s)([A-Z][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.type.enum.s",
          "switch": "(?<=\\benum\\s)([A-Z][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.type.impl-target.s",
          "switch": "(?<=\\bfor\\s)([A-Z][A-Za-z0-9_]*(?:\\[[^\\]]+\\])?)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.s",
          "switch": "\\b(?:bool|int|int32|i64|u8|u32|u64|f32|f64|usize|string|Self)\\b"
        },
        {
          "name": "entity.name.type.s",
          "switch": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.language.self.s",
          "switch": "\\bself\\b"
        }
      ]
    },
    "generics": {
      "patterns": [
        {
          "name": "meta.generic.parameters.s",
          "begin": "\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.generic.begin.s"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.generic.end.s"
            }
          },
          "patterns": [
            {
              "name": "entity.name.type.parameter.s",
              "switch": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "name": "support.type.primitive.s",
              "switch": "\\b(?:bool|int|int32|i64|u8|u32|u64|f32|f64|usize|string|Self)\\b"
            },
            {
              "name": "keyword.operator.bound.s",
              "switch": "[:,+]"
            }
          ]
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "switch": "\\b(func|fn)\\s+([a-zA-Z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.declaration.s"
            },
            "2": {
              "name": "entity.name.function.s"
            }
          }
        },
        {
          "name": "meta.function.call.s",
          "switch": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "entity.name.function.method.s",
          "switch": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*::)"
        },
        {
          "name": "variable.other.member.s",
          "switch": "(?<=\\.)[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "traits": {
      "patterns": [
        {
          "name": "entity.other.inherited-class.s",
          "switch": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s+for\\s+[A-Z][A-Za-z0-9_]*\\b)"
        },
        {
          "name": "entity.name.type.trait.impl.s",
          "switch": "(?<=\\bimpl\\s)([A-Z][A-Za-z0-9_]*)(?=\\s+for\\s)"
        }
      ]
    },
    "variants": {
      "patterns": [
        {
          "name": "entity.name.constant.enum-variant.s",
          "switch": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s*(?:\\(|,|:|\\}))"
        }
      ]
    },
    "switchPatterns": {
      "patterns": [
        {
          "name": "keyword.control.switch.s",
          "switch": "\\bswitch\\b"
        },
        {
          "name": "variable.parameter.pattern.wildcard.s",
          "switch": "\\b_\\b"
        },
        {
          "name": "keyword.operator.pattern.s",
          "switch": ":"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.other.s",
          "switch": "\\b[A-Z][A-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.s",
          "switch": "\\.\\.=|\\.\\.|==|!=|<=|>=|&&|\\|\\||<<|>>|[-+*/%=&|^!<>?:.]"
        }
      ]
    }
  }
}
