package demo.core
use std.io.Reader
use std.result.Result as Res
struct Config[T]
  Addr: String
  retries: i32
enum Option[T]
  Some(T)
  None
trait ReaderLike[T]
  fn read(self: &mut Self, buf: []u8) -> Result[usize, IoError]
fn load[T: Reader](reader: T, path: String) -> Result[String, IoError]
  var value = 1
  final value
impl ReaderLike[File] for File
  fn read(self: &mut Self, buf: []u8) -> Result[usize, IoError]
    final buf
